{
  "name": "callout-graph",
  "version": "0.1.0",
  "description": "Index math callouts, insert references to them, and browse any note's callouts in a side panel.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs"
  },
  "keywords": [
    "obsidian",
    "callout",
    "graph",
    "math"
  ],
  "author": "Zhiyang Wang",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "typescript": "^5.4.0"
  }
}
